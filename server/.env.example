# =================================
# REQUIRED ENVIRONMENT VARIABLES
# =================================

# MongoDB Atlas (REQUIRED)
# Obtain from https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/healthblog?retryWrites=true&w=majority

# OpenAI API Key (REQUIRED for blog post generation)
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# Perplexity API Key (REQUIRED for trend analysis)
# Obtain from https://api.perplexity.ai
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=pplx-7b-online

# Admin API Key (REQUIRED for protecting admin endpoints)
# Generate a strong random string (e.g., using: openssl rand -hex 32)
# Used to authenticate requests to /api/admin/* endpoints
ADMIN_API_KEY=your-secure-random-api-key-here

# =================================
# OPTIONAL SERVER CONFIGURATION
# =================================

# Server Port
PORT=3001

# Environment
NODE_ENV=development

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:5173

# HMR Configuration (for remote deployments like Fly.io)
# VITE_HMR_HOST=your-domain.fly.dev
# VITE_HMR_PORT=443
# VITE_HMR_PROTOCOL=wss

# =================================
# SCHEDULING CONFIGURATION
# =================================

# Trend analysis runs at this time (24-hour format, UTC)
TREND_ANALYSIS_TIME=06:00

# Blog post publication times (24-hour format, UTC)
SCHEDULE_TIME_1=09:00
SCHEDULE_TIME_2=14:00
SCHEDULE_TIME_3=18:00

# Number of posts to generate per day
POSTS_PER_DAY=3

# =================================
# CONTENT GENERATION CONFIGURATION
# =================================

# Target word count per generated post
WORDS_PER_POST=1000

# Default author name for AI-generated posts
AUTHOR_NAME=Health Blogger
