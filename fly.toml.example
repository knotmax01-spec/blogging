# Fly.toml file for Health Blog AI platform
# See https://fly.io/docs/reference/configuration/ for information about all these options.

app = "health-blog-ai"
primary_region = "ord"

[build]
  builder = "heroku"
  buildpacks = ["heroku/nodejs"]

[env]
  MONGODB_URI = "YOUR_MONGODB_ATLAS_CONNECTION_STRING"
  OPENAI_API_KEY = "YOUR_OPENAI_API_KEY"
  PERPLEXITY_API_KEY = "YOUR_PERPLEXITY_API_KEY"
  SCHEDULE_TIME_1 = "09:00"
  SCHEDULE_TIME_2 = "14:00"
  SCHEDULE_TIME_3 = "18:00"
  AUTHOR_NAME = "Health Blogger"
  WORDS_PER_POST = "1000"
  NODE_ENV = "production"

[http_service]
  internal_port = 5173
  force_https = true
  auto_stop_machines = true
  auto_start_machines = true
  min_machines_running = 1

[[services]]
  processes = ["api"]
  protocol = "tcp"
  internal_port = 3001
  
  [[services.ports]]
    port = 3001
    handlers = ["http"]
    force_https = false
